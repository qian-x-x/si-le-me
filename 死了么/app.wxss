page {
  background-color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  --bg-color: #ffffff;
  --text-color: #000000;
  --text-secondary: #666666;
  --btn-color: #000000;
  --btn-text: #ffffff;
  --danger-color: #ff3b30;
  --success-color: #34c759;
  --border-color: #e5e5e5;
}

/* 弥散背景容器 - 简化版适应黑白主题 */
.gradient-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 800rpx;
  overflow: hidden;
  z-index: 0;
  pointer-events: none;
  background: linear-gradient(180deg, #f5f5f5 0%, #ffffff 100%);
}

/* 弥散光斑 - 黑色系 */
.gradient-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(150rpx);
}

.blob-1 {
  width: 500rpx;
  height: 500rpx;
  background: #000000;
  opacity: 0.05;
  top: -200rpx;
  left: -150rpx;
}

.blob-2 {
  width: 600rpx;
  height: 600rpx;
  background: #333333;
  opacity: 0.05;
  top: -100rpx;
  right: -200rpx;
}

.blob-3 {
  width: 400rpx;
  height: 400rpx;
  background: #000000;
  opacity: 0.03;
  top: 150rpx;
  left: 30%;
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
  margin: 0 32rpx 24rpx;
  border: 1rpx solid var(--border-color);
}

/* 自定义导航栏 */
.custom-nav {
  position: relative;
  z-index: 10;
  padding-top: 88rpx;
}

.nav-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #000000;
  padding: 20rpx 0;
}

/* 页面容器 */
.page-container {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  background-color: #ffffff;
  padding-bottom: 180rpx;
}

.content {
  padding-top: 20rpx;
}

/* 通用按钮样式 */
.btn-primary {
  background-color: var(--btn-color);
  color: var(--btn-text);
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.8;
}

/* 危险按钮 */
.btn-danger {
  background-color: var(--danger-color);
  color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

/* 警告提示 */
.warning-text {
  color: var(--danger-color);
}

/* 成功提示 */
.success-text {
  color: var(--success-color);
}
