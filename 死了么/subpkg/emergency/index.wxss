.page-container {
  min-height: 100vh;
  background-color: #ffffff;
}

.custom-nav {
  position: relative;
  z-index: 10;
  padding-top: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 20rpx;
  background-color: #ffffff;
}

.nav-back {
  position: absolute;
  left: 24rpx;
  padding: 10rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #000000;
}

.content {
  padding: 32rpx;
}

/* 表单卡片 */
.form-card {
  padding: 40rpx 32rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 12rpx;
}

.form-desc {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #000000;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #000000;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #999999;
}

/* 保存按钮 */
.save-btn-area {
  padding: 32rpx 0;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background-color: #000000;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn:active {
  background-color: #333333;
}

/* 温馨提示 */
.notice-card {
  padding: 32rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 16rpx;
}

.notice-item {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}
