.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #f8fafc;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 32rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.version {
  font-size: 26rpx;
  color: #999;
}

.divider {
  width: 120rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #60a5fa, transparent);
  margin: 48rpx 0;
}

.desc {
  font-size: 28rpx;
  color: #60a5fa;
  font-weight: 500;
}
