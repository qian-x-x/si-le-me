.container {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 60rpx;
}

.detail-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 32rpx 24rpx;
}

/* 封面图 */
.cover-image {
  width: 100%;
  height: 400rpx;
}

/* 信息卡片 */
.info-card {
  padding: 32rpx;
  margin-top: -40rpx;
  position: relative;
}

.info-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.info-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.info-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
}

/* 内容卡片 */
.content-card {
  padding: 32rpx;
}

.content-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}
