.page-container {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  background-color: #ffffff;
  padding-bottom: 180rpx;
}

.content {
  padding-top: 20rpx;
}

/* 用户信息 */
.user-section {
  display: flex;
  align-items: center;
  padding: 48rpx 40rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #000000;
}

.user-info {
  flex: 1;
  margin-left: 28rpx;
}

.username {
  font-size: 38rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 8rpx;
}

.uid {
  font-size: 24rpx;
  color: #666666;
}

/* 签到统计卡片 */
.stats-card {
  padding: 32rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 24rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #000000;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
  margin-top: 8rpx;
}

/* 菜单卡片 */
.menu-card {
  padding: 0 32rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-left text {
  font-size: 30rpx;
  color: #000000;
  margin-left: 20rpx;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-value {
  font-size: 28rpx;
  color: #666666;
  margin-right: 8rpx;
}

.menu-placeholder {
  font-size: 28rpx;
  color: #999999;
  margin-right: 8rpx;
}

.menu-count {
  font-size: 28rpx;
  color: #666666;
  margin-right: 8rpx;
}

.menu-divider {
  height: 1rpx;
  background-color: #e5e5e5;
}

/* 提醒说明 */
.notice-card {
  padding: 32rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 16rpx;
}

.notice-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}
